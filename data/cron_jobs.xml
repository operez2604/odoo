<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_check_overdue_loans" model="ir.cron">
        <field name="name">Verificar Préstamos Vencidos</field>
        <field name="model_id" ref="model_library_loan"/>
        <field name="state">code</field>
